@page "/"
@rendermode InteractiveServer
<PageTitle>LunenusErp - Современная ERP система</PageTitle>

<!-- Hero Section -->
<section class="hero-section back mb-4 radius p-4 text-white py-4">
    <div class="container radius mb-4">
        <div class="row">
            <div class="col-lg-6 mb-3 mb-lg-2 align-content-lg-center p-5">
                <h1 class="display-4 fw-bold mb-3">
                    Lunenus<span class="text-black">Erp</span>
                </h1>
                <p class="lead mb-1">
                    Полное управление бизнес-процессами в<br>единой экосистеме
                </p>
                <br>
                <div class="d-flex gap-2">
                    <a href="/faq" class="btn btn-outline-light btn-lg px-4">Возможности</a>
                </div>
            </div>
            <div class="col-lg-6">
                <img src="/20260228_2327_Image Generation_simple_compose_01kjjyx2gcece9gwm34ba9yzv3.png" alt="LunenusErp Dashboard"
                     class="img-fluid rounded-3 animate__animated animate__fadeInRight">
            </div>
        </div>
    </div>
</section>

<style>
    .hero-section {
        min-height: auto !important; /* если был задан min-height */
        padding-top: 2rem !important;
        padding-bottom: 2rem !important;
    }
</style>

<!-- Преимущества -->
<section class="features-section radius mb-5 py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Почему выбирают LunenusErp</h2>
            <p class="lead text-muted">Комплексное решение для вашего бизнеса</p>
        </div>

        <div class="row g-4">
            @foreach (var feature in features)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <div class="card-body text-center p-4">
                            <div class="feature-icon mb-3">
                                <i class="bi @feature.Icon fs-1 text-primary"></i>
                            </div>
                            <h3 class="h4 mb-3">@feature.Title</h3>
                            <p class="text-muted">@feature.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Статистика -->
<section class="stats-section py-5 bg-primary text-white radius mb-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-4 mb-md-0">
                <div class="stat-item">
                    <div class="display-3 fw-bold">500+</div>
                    <div class="h6">Компаний доверяют</div>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4 mb-md-0">
                <div class="stat-item">
                    <div class="display-3 fw-bold">24/7</div>
                    <div class="h6">Поддержка</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="display-3 fw-bold">99.9%</div>
                    <div class="h6">Аптайм</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="display-3 fw-bold">50+</div>
                    <div class="h6">Интеграций</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Ключевые модули -->
<section class="modules-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Основные модули системы</h2>
            <p class="lead text-muted">Всё необходимое для управления бизнесом</p>
        </div>

        <div class="row g-4">
            @foreach (var module in modules)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="module-card p-4 border rounded-3 hover-shadow bg-white h-100">
                        <div class="d-flex align-items-center mb-3">
                            <div class="module-icon me-3">
                                <i class="bi @module.Icon fs-2 text-primary"></i>
                            </div>
                            <h3 class="h5 mb-0">@module.Title</h3>
                        </div>
                        <p class="text-muted mb-3">@module.Description</p>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar"
                                 style="width: @module.Progress%"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>



@code {
